# Ignoring generated files, as they pollute pull requests and can create merge conflicts
# Only the Flutter-generated xcconfigs are ignored — Debug/Release xcconfig and the
# Podfile are normal project files and must be committed, or the store builds fail.
**/Flutter/Generated.xcconfig
**/Flutter/Flutter-Generated.xcconfig
*.g.dart
*.freezed.dart

pubspec.lock
generated

#melos
pubspec_overrides.yaml
screenshots

#  windows build files
**/MANUAL_COMPILATION_STEPS.md
**/Output/
**/WINDOWS_DISTRIBUTION_README.md
**/build-windows-installer.bat
**/compile-installer.bat
**/compile-installer.ps1
**/distribution/
*.iss

# Miscellaneous
*.class
*.log
*.pyc``
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
.cxx
release/release_state.json

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/

#snap
*.snap
**/parts/**
**/prime/**
**/stage/**

# Web related
lib/generated_plugin_registrant.dart

# iOS generated plugin registrant
**/GeneratedPluginRegistrant.m
**/GeneratedPluginRegistrant.h

# iOS/macOS Flutter generated files
**/ios/Flutter/flutter_export_environment.sh
**/Flutter/ephemeral/

# Example-app generated desktop runner + local tests (regeneratable / local-only)
packages/*/example/linux/
packages/*/example/test/

# Exceptions to above rules.
!/packages/flutter_tools/test/data/dart_dependencies_test/**/.packages
