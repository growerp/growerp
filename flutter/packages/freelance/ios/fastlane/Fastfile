# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

def normalized_env(key)
  ENV[key].to_s.gsub("\r", "").strip
end

def required_env!(key)
  value = normalized_env(key)
  UI.user_error!("Missing required environment variable #{key}. Set the GitHub secret or export it before running fastlane.") if value.empty?
  value
end

def optional_env(key)
  value = normalized_env(key)
  value.empty? ? nil : value
end

platform :ios do
  lane :build do
    increment_build_number
    build_app(scheme: "GrowERPfreelance")
  end
  lane :ci_build do
    build_app(
      scheme: "Runner",
      export_method: "app-store",
      buildlog_path: "/tmp/xcodebuild-ios-logs",
      disable_xcpretty: true,
      xcargs: "GCC_OPTIMIZATION_LEVEL=s SWIFT_COMPILATION_MODE=wholemodule"
    )
  end
  lane :codesign do
    api_key = app_store_connect_api_key(
      key_id:                required_env!("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id:             required_env!("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_content:           required_env!("APP_STORE_CONNECT_API_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house:              false
    )
    options = {
      type: "appstore",
      readonly: true,
      api_key: api_key,
      git_url: required_env!("MATCH_GIT_URL")
    }
    auth = optional_env("MATCH_GIT_BASIC_AUTHORIZATION")
    options[:git_basic_authorization] = auth if auth
    sync_code_signing(**options)
  end
  lane :upload do
    upload_to_testflight
  end  
end