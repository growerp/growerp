<?xml version="1.0" encoding="UTF-8"?>
<!-- No copyright or license for configuration file, details here are not considered a creative
work. -->
<moqui-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/moqui-conf-2.1.xsd">
    <screen-facade>
        <!-- because no-sub-path this is the root url.-->
        <screen location="component://webroot/screen/webroot.xml" default-subscreen="m">
            <subscreens-item name="m" menu-title="GrowERP Ecommerce" menu-include="false"
                    location="component://PopRestStore/screen/store.xml" no-sub-path="true"/>
        </screen>
        <!-- single page for the url /website -->
        <screen location="component://webroot/screen/webroot.xml">
            <!-- website is the path -->
            <subscreens-item name="website" location="component://PopRestStore/screen/website.xml" />
        </screen>
        <!-- single page for the url /checkoutOnePage -->
        <screen location="component://webroot/screen/webroot.xml">
            <subscreens-item name="checkoutOnePage" location="component://PopRestStore/screen/checkoutOnePage.xml" />
        </screen>
        <!-- Assessment app - serves index.html and allows Moqui to serve other resources like
        main.dart.mjs, etc -->
        <screen location="component://webroot/screen/webroot.xml">
            <subscreens-item name="assessment" location="component://PopRestStore/screen/assessmentApp.xml" no-sub-path="true"/>
        </screen>
        <!-- Generic, tenant-scoped, data-driven landing page renderer: /landing/{pseudoId}
             (pseudoId resolved per-tenant from the request hostname) -->
        <screen location="component://webroot/screen/webroot.xml">
            <subscreens-item name="landing" location="component://PopRestStore/screen/landingPage.xml" />
        </screen>
        <!-- /assessmentLanding kept as an alias of /landing for backward compatibility with
             already-published URLs; same screen, same default pseudoId (erp-landing-page) -->
        <screen location="component://webroot/screen/webroot.xml">
            <subscreens-item name="assessmentLanding" location="component://PopRestStore/screen/landingPage.xml" />
        </screen>
        <!-- /spreadsheetFreedom kept as a redirect to /landing/spreadsheet-freedom for
             already-circulated marketing links -->
        <screen location="component://webroot/screen/webroot.xml">
            <subscreens-item name="spreadsheetFreedom" location="component://PopRestStore/screen/spreadsheetFreedomGuide.xml" />
        </screen>
    </screen-facade>
</moqui-conf>