<!-- Local XSD is used instead of the upstream http://moqui.org/xsd/xml-screen-2.1.xsd because
     it has been patched to allow '.' at the first position and '-' anywhere in transition names.
     Path is relative to the source location; at Moqui runtime this file is symlinked under
     moqui/runtime/component/PopRestStore/screen/ where ../../../../framework/xsd/... would apply. -->
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../moqui/framework/xsd/xml-screen-3.xsd"
    standalone="true" require-authentication="anonymous-view" allow-extra-path="true">

    <always-actions>
        <service-call name="popstore.StoreServices.get#ProductStoreIdFromHostName" in-map="[
            requestHostName: (ec.web.getHostName(false) == '10.0.2.2' ? 'localhost' : ec.web.getHostName(false))]" out-map="productStoreIdContext"/>
        <set field="productStoreId" value="${productStoreIdContext.productStoreId ?: 'POPC_DEFAULT'}"/>

        <service-call name="popstore.StoreServices.get#StoreInfo" in-map="[productStoreId:productStoreId]" out-map="storeInfo"/>
        <set field="productStore" from="storeInfo.productStore"/>
        <set field="wikiSpaceId" from="productStore?.wikiSpaceId"/>

        <if condition="ec.user.userAccount">
            <entity-find-one entity-name="mantle.party.PartyDetail" value-field="partyDetail">
                <field-map field-name="partyId" from="ec.user.userAccount.partyId"/>
            </entity-find-one>
        </if>
    </always-actions>

    <transition name="getLogo" read-only="true"><!--
        should use rest interface -->
        <actions>
            <entity-find entity-name="mantle.party.PartyContent" list="partyContentList" cache="true">
                <econdition field-name="partyContentTypeEnumId" value="PcntLogoImage"/>
                <econdition field-name="partyId" from="productStore.organizationPartyId"/>
            </entity-find>
            <if condition="partyContentList">
                <script>ec.web.sendResourceResponse(partyContentList[0].contentLocation, true)</script>
                <else>
                    <script>ec.web.sendResourceResponse("dbresource://GrowERP/images/growerp_logo.jpg", true)</script>
                </else>
            </if>
        </actions><default-response type="none"/>
    </transition>

    <transition name="getContent" read-only="true"><!--
        should use rest interface -->
        <parameter name="contentId"/>
        <actions>
            <entity-find entity-name="mantle.party.PartyContent" list="partyContentList" cache="true">
                <econdition field-name="partyContentTypeEnumId" value="PcntInternal"/>
                <econdition field-name="partyId" from="productStore.organizationPartyId"/>
                <econdition field-name="contentId"/>
            </entity-find>
            <if condition="partyContentList">
                <script>ec.web.sendResourceResponse(partyContentList[0].contentLocation, true)</script>
                <else>
                    <script>ec.web.sendResourceResponse("dbresource://GrowERP/images/growerp_logo.jpg", true)</script>
                </else>
            </if>
        </actions><default-response type="none"/>
    </transition>

    <transition name="getImage" read-only="true">
        <!-- should use rest interface -->
        <actions>
            <entity-find entity-name="growerp.store.ProductStoreContent" list="storeImages" cache="true" limit="1">
                <econdition field-name="productStoreId" from="productStore.productStoreId"/>
                <econdition field-name="contentTypeEnumId" value="PrstImageLarge"/>
                <econdition field-name="description" operator="like" value="${sri.screenUrlInfo.extraPathNameList.join('/')}%" ignore-case="true"/>
            </entity-find>
            <if condition="storeImages">
                <script>ec.web.sendResourceResponse(storeImages[0].contentLocation, true)</script>
                <else>
                    <script>logger.error("== image: ${sri.screenUrlInfo.extraPathNameList.join('/')} not found")</script>
                </else>
            </if>
        </actions><default-response type="none"/>
    </transition>

    <transition name=".well-known" read-only="true">
        <actions>
            <set field="fileName" from="sri.screenUrlInfo.extraPathNameList[0]"/>
            <if condition="fileName == 'assetlinks.json' || fileName == 'apple-app-site-association'">
                <entity-find-one entity-name="moqui.resource.wiki.WikiSpace" value-field="wikiSpace">
                    <field-map field-name="wikiSpaceId"/>
                </entity-find-one>
                <if condition="wikiSpace">
                    <set field="resourceLocation" value="${wikiSpace.rootPageLocation}/.well-known/${fileName}"/>
                    <set field="resourceRef" from="ec.resource.getLocationReference(resourceLocation)"/>
                    <if condition="resourceRef != null">
                        <script>ec.web.sendTextResponse(resourceRef.getText(), "application/json", null)</script>
                        <else>
                            <script>ec.web.sendError(404, "File not found: ${fileName}", null)</script>
                        </else>
                    </if>
                </if>
            </if>
        </actions>
        <default-response type="none"/>
    </transition>

    <transition name="config.js" read-only="true">
        <actions>
            <script><![CDATA[
                // NOTE: storeInfo prepared in always-actions above
                // set productStoreId in the session
                ec.web.sessionAttributes.productStoreId = productStoreId
                // add apiKey and moquiSessionToken for current user and session
                if (ec.user.username) { try { storeInfo.apiKey = ec.user.getLoginKey() } catch (Exception e) { } }
                else storeInfo.apiKey = null
                storeInfo.moquiSessionToken = ec.web.sessionToken
                String partyId = (ec.user.username ? ec.user.userAccount?.partyId : null) ?: ec.web.sessionAttributes.customerPartyId
                if (partyId) { storeInfo.customerInfo = ec.service.sync().name("popstore.CustomerServices.get#CustomerInfo").call() }
                // generate and send the JS response
                String storeInfoJson = groovy.json.JsonOutput.toJson(storeInfo)
                String jsText = """
var storeInfo = ${storeInfoJson};
\$.extend(storeConfig, storeInfo.productStore, storeInfo.settings);
"""
                ec.web.sendTextResponse(jsText, "application/javascript", null)
            ]]></script>
        </actions>
        <default-response type="none"/>
    </transition>

    <transition name="logOut" read-only="true">
        <actions>
            <service-call name="popstore.CustomerServices.logout#Customer"/>
        </actions>
        <default-response url="."/>
    </transition>

    <subscreens default-item="home" always-use-full-path="true"/>

    <pre-actions>
        <set field="home" value="/"/>
        <!-- lookup configured browse root category from storeInfo -->
        <set field="browseRootCategory" from="storeInfo.categoryByType.PsctBrowseRoot"/>
        <set field="browseRootCategoryId" from="browseRootCategory?.productCategoryId"/>
        <!-- get browseRootCategoryInfo for subCategoryList used in header, etc -->
        <if condition="browseRootCategoryId">
            <service-call name="popstore.ProductServices.get#CategoryInfo" out-map="browseRootCategoryInfo"
                in-map="[productCategoryId:browseRootCategoryId]"/>
        </if>
        <!-- get allProductsInfo for subCategoryList used in header, etc --> 
        <set field="allProducts" from="storeInfo.categoryByType.PsctSearch"/>
        <set field="allProductsId" from="storeInfo.categoryByType.PsctSearch?.productCategoryId"/>
        <if condition="allProductsId">
            <service-call name="popstore.ProductServices.get#CategoryInfo" out-map="allProductsInfo"
                in-map="[productCategoryId:allProductsId]"/>
        </if>
        <!-- cartInfo for cart count in header/navbar -->
        <service-call name="popstore.CartServices.get#CartInfo" out-map="cartInfo" in-map="context"/>

        <!-- get css data in json format -->
        <set field="location" value="${storeInfo.settings.PsstContentLocation}/content/websiteColor.json"/>
        <set field="contentRef" from="ec.resource.getLocationReference(location)"/>
        <set field="style" value="{}"/>
        <if condition="contentRef != null">
            <set field="text" from="contentRef.getText()"/>
            <if condition="text != null">
                <set field="style" from="text"/>
            </if>
        </if>
        <!-- create own version of styles.css -->
        <script>
            import groovy.json.JsonSlurper
            // get settings
            JsonSlurper slurper = new JsonSlurper()
            context.putAll(slurper.parseText(style))
            // get target filepath
            newRef = ec.resource.getLocationReference("component://PopRestStore/screen/store/components/styles/${storeInfo.productStore.productStoreId}.css")
            String newFilePath = newRef.getUrl().toExternalForm().substring(5)
            // render ftl file
            String location = "component://PopRestStore/screen/store/components/styles.css.ftl"
            css = ec.resource.getTemplateRendererByLocation(location)
            Writer fw = new FileWriter(newFilePath)
            css.render(location, fw)
            fw.close()
      </script>

        <!-- get company contact info for footer -->
        <entity-find entity-name="mantle.party.contact.PartyContactMech" list="postalContactList" limit="1">
            <econdition field-name="partyId" from="productStore.organizationPartyId"/>
            <econdition field-name="contactMechPurposeId" value="PostalPrimary"/>
            <date-filter/>
        </entity-find>
        <if condition="postalContactList">
            <entity-find-one entity-name="mantle.party.contact.PostalAddress" value-field="companyPostalAddress">
                <field-map field-name="contactMechId" from="postalContactList[0].contactMechId"/>
            </entity-find-one>
        </if>
        <entity-find entity-name="mantle.party.contact.PartyContactMech" list="phoneContactList" limit="1">
            <econdition field-name="partyId" from="productStore.organizationPartyId"/>
            <econdition field-name="contactMechPurposeId" value="PhonePrimary"/>
            <date-filter/>
        </entity-find>
        <if condition="phoneContactList">
            <entity-find-one entity-name="mantle.party.contact.TelecomNumber" value-field="companyPhone">
                <field-map field-name="contactMechId" from="phoneContactList[0].contactMechId"/>
            </entity-find-one>
        </if>
        <entity-find entity-name="mantle.party.contact.PartyContactMech" list="emailContactList" limit="1">
            <econdition field-name="partyId" from="productStore.organizationPartyId"/>
            <econdition field-name="contactMechPurposeId" value="EmailPrimary"/>
            <date-filter/>
        </entity-find>
        <if condition="emailContactList">
            <entity-find-one entity-name="mantle.party.contact.ContactMech" value-field="companyEmailMech">
                <field-map field-name="contactMechId" from="emailContactList[0].contactMechId"/>
            </entity-find-one>
        </if>

        <!-- get settings used in subscreens -->
        <set field="template_server_root" from="storeInfo.settings.template_server_root" default-value="component://PopRestStore/template/store/root.html.ftl"/>
        <set field="template_server_header" from="storeInfo.settings.template_server_header" default-value="component://PopRestStore/template/store/navbar.html.ftl"/>
        <set field="template_server_footer" from="storeInfo.settings.template_server_footer" default-value="component://PopRestStore/template/store/footer.html.ftl"/>
        <set field="template_server_home" from="storeInfo.settings.template_server_home" default-value="component://PopRestStore/template/store/home.html.ftl"/>
        <set field="template_server_category" from="storeInfo.settings.template_server_category" default-value="component://PopRestStore/template/store/category.html.ftl"/>
        <set field="template_server_product" from="storeInfo.settings.template_server_product" default-value="component://PopRestStore/template/store/product.html.ftl"/>
        <set field="template_server_content" from="storeInfo.settings.template_server_content" default-value="component://PopRestStore/template/store/help.html.ftl"/>
        <set field="template_server_search" from="storeInfo.settings.template_server_search" default-value="component://PopRestStore/template/store/search.html.ftl"/>
    </pre-actions>

    <widgets>
        <section name="website" condition="productStoreId != null &amp;&amp; productStoreId != 'POPC_DEFAULT'">
            <widgets>
                <render-mode><text type="html" location="${template_server_root}"></text></render-mode>
            </widgets>
            <fail-widgets>
                <label text="${ec.web.sendError(404, 'Not a valid website url', null)}"/>
            </fail-widgets>
        </section>
        <!-- floating chat-inquiry button: separate section so it always renders after the store page -->
        <section name="chat-button" condition="productStoreId != null &amp;&amp; productStoreId != 'POPC_DEFAULT'">
            <widgets>
                <render-mode>
                    <text type="html"><![CDATA[
<style>
#growerp-chat-btn{position:fixed;right:20px;bottom:20px;z-index:2147483000;
  display:flex;align-items:center;gap:10px;cursor:pointer;
  background:#2962ff;color:#fff;border:none;border-radius:28px;
  height:56px;padding:0 16px;box-shadow:0 4px 14px rgba(0,0,0,.25);
  font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.2;
  max-width:56px;overflow:hidden;white-space:nowrap;
  transition:max-width .4s ease,border-radius .4s ease,background .2s ease}
#growerp-chat-btn svg{flex:0 0 auto;width:24px;height:24px;fill:#fff}
#growerp-chat-btn .growerp-chat-label{opacity:0;transition:opacity .3s ease .1s}
#growerp-chat-btn.growerp-expanded{max-width:260px;border-radius:14px}
#growerp-chat-btn.growerp-expanded .growerp-chat-label{opacity:1}
#growerp-chat-panel{position:fixed;right:20px;bottom:86px;z-index:2147483000;
  width:320px;max-width:calc(100vw - 40px);display:none;flex-direction:column;
  background:#fff;color:#222;border-radius:12px;overflow:hidden;
  box-shadow:0 8px 28px rgba(0,0,0,.3);font-family:Arial,Helvetica,sans-serif}
#growerp-chat-panel.growerp-open{display:flex}
#growerp-chat-panel .growerp-chat-head{background:#2962ff;color:#fff;
  padding:12px 14px;font-size:15px;font-weight:bold}
#growerp-chat-panel .growerp-chat-body{padding:14px;display:flex;flex-direction:column;gap:10px}
#growerp-chat-panel label{font-size:12px;color:#555}
#growerp-chat-panel input,#growerp-chat-panel textarea{
  width:100%;box-sizing:border-box;border:1px solid #ccc;border-radius:6px;
  padding:8px;font-size:14px;font-family:inherit}
#growerp-chat-panel textarea{resize:vertical;min-height:72px}
#growerp-chat-panel button.growerp-chat-send{background:#2962ff;color:#fff;border:none;
  border-radius:6px;padding:10px;font-size:14px;cursor:pointer}
#growerp-chat-panel button.growerp-chat-send:disabled{opacity:.6;cursor:default}
#growerp-chat-status{font-size:13px;min-height:18px}
#growerp-chat-status.growerp-err{color:#c62828}
#growerp-chat-status.growerp-ok{color:#2e7d32}
</style>
<button id="growerp-chat-btn" type="button" aria-label="Ask a question">
  <svg viewBox="0 0 24 24"><path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-2 9H6V9h12v2zm0-3H6V6h12v2z"/></svg>
  <span class="growerp-chat-label">Question?<br>we answer within one day</span>
</button>
<div id="growerp-chat-panel" role="dialog" aria-label="Ask a question">
  <div class="growerp-chat-head">Ask us a question</div>
  <div class="growerp-chat-body">
    <div>
      <label for="growerp-chat-email">Your email *</label>
      <input id="growerp-chat-email" type="email" required placeholder="you@example.com"/>
    </div>
    <div>
      <label for="growerp-chat-question">Your question *</label>
      <textarea id="growerp-chat-question" placeholder="How can we help?"></textarea>
    </div>
    <div id="growerp-chat-status"></div>
    <button class="growerp-chat-send" type="button">Send</button>
  </div>
</div>
<script>
(function(){
  var productStoreId = "${productStoreId}";
  var btn = document.getElementById('growerp-chat-btn');
  var panel = document.getElementById('growerp-chat-panel');
  var emailEl = document.getElementById('growerp-chat-email');
  var questionEl = document.getElementById('growerp-chat-question');
  var statusEl = document.getElementById('growerp-chat-status');
  var sendBtn = panel.querySelector('.growerp-chat-send');

  // one-time animation: icon → label (after 3s) → back to icon (after 2s)
  var animDone = false;
  setTimeout(function(){
    if (!panel.classList.contains('growerp-open')) btn.classList.add('growerp-expanded');
    setTimeout(function(){
      if (!panel.classList.contains('growerp-open')) btn.classList.remove('growerp-expanded');
      animDone = true;
    }, 2000);
  }, 3000);

  // hover: expand on mouseenter, shrink on mouseleave (not while panel is open)
  btn.addEventListener('mouseenter', function(){
    btn.classList.add('growerp-expanded');
  });
  btn.addEventListener('mouseleave', function(){
    if (!panel.classList.contains('growerp-open')) btn.classList.remove('growerp-expanded');
  });

  function setStatus(msg, kind){
    statusEl.textContent = msg || '';
    statusEl.className = kind ? ('growerp-' + kind) : '';
  }

  btn.addEventListener('click', function(){
    var isOpen = panel.classList.toggle('growerp-open');
    if (isOpen) {
      btn.classList.add('growerp-expanded');
      emailEl.focus();
    } else {
      btn.classList.remove('growerp-expanded');
    }
  });

  function validEmail(v){ return /^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(v); }

  sendBtn.addEventListener('click', function(){
    var email = (emailEl.value || '').trim();
    var question = (questionEl.value || '').trim();
    if (!validEmail(email)){ setStatus('Please enter a valid email address.', 'err'); emailEl.focus(); return; }
    if (!question){ setStatus('Please enter your question.', 'err'); questionEl.focus(); return; }
    setStatus('Sending...', '');
    sendBtn.disabled = true;
    fetch(window.location.origin + '/rest/s1/growerp/100/WebsiteChat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productStoreId: productStoreId, email: email, question: question })
    }).then(function(r){
      if (!r.ok) throw new Error('http ' + r.status);
      return r.json();
    }).then(function(){
      setStatus('Thanks! We answer within one day.', 'ok');
      emailEl.value = ''; questionEl.value = '';
      sendBtn.disabled = false;
      setTimeout(function(){ panel.classList.remove('growerp-open'); setStatus('', ''); }, 3000);
    }).catch(function(){
      setStatus('Sorry, something went wrong. Please try again.', 'err');
      sendBtn.disabled = false;
    });
  });
})();
</script>
]]></text>
                </render-mode>
            </widgets>
        </section>
    </widgets>
</screen>