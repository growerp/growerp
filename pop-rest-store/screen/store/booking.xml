<!-- Public appointment booking page: /booking. Lists the company's AVAILABLE
     slots and books one via the anonymous Booking REST endpoints. -->
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-2.1.xsd"
    require-authentication="anonymous-view" history="false">

    <widgets>
        <render-mode><text type="html" location="${template_server_header}"/></render-mode>
        <render-mode><text type="html"><![CDATA[
<div style="max-width:560px;margin:32px auto;padding:0 16px;font-family:inherit">
  <h2>Book an appointment</h2>
  <div id="growerp-booking">Loading available times…</div>
</div>
<style>
#growerp-booking .growerp-slot{display:block;width:100%;text-align:left;margin:6px 0;
  padding:10px 14px;border:1px solid #ccc;border-radius:8px;background:rgba(255,255,255,.85);
  color:#222;cursor:pointer;font-size:14px}
#growerp-booking .growerp-slot.growerp-sel{border-color:#2962ff;outline:2px solid #2962ff}
#growerp-booking label{display:block;font-size:13px;margin:10px 0 4px}
#growerp-booking input,#growerp-booking textarea{width:100%;box-sizing:border-box;
  border:1px solid #ccc;border-radius:6px;padding:8px;font-size:14px;font-family:inherit}
#growerp-booking button.growerp-book{margin-top:14px;background:#2962ff;color:#fff;border:none;
  border-radius:6px;padding:10px 18px;font-size:14px;cursor:pointer}
#growerp-booking .growerp-status{font-size:13px;min-height:18px;margin-top:8px}
#growerp-booking .growerp-err{color:#c62828}
#growerp-booking .growerp-ok{color:#2e7d32;font-size:16px}
</style>
<script>
(function(){
  var storeId = '${productStoreId}';
  var api = window.location.origin + '/rest/s1/growerp/100/Booking';
  var holder = document.getElementById('growerp-booking');
  var selected = null;
  fetch(api + '?productStoreId=' + encodeURIComponent(storeId),
      {headers:{'Accept':'application/json'}})
    .then(function(r){ return r.ok ? r.json() : null; })
    .then(function(j){
      holder.textContent = '';
      if (!j || !j.slots || !j.slots.length) {
        holder.textContent = 'No times available right now — please check back later.';
        return;
      }
      j.slots.forEach(function(s){
        var b = document.createElement('button');
        b.type = 'button'; b.className = 'growerp-slot';
        b.textContent = new Date(s.startDateTime.replace(' ','T')).toLocaleString() +
          ' — ' + new Date(s.endDateTime.replace(' ','T')).toLocaleTimeString();
        b.addEventListener('click', function(){
          selected = s.slotId;
          holder.querySelectorAll('.growerp-slot').forEach(function(x){
            x.classList.remove('growerp-sel'); });
          b.classList.add('growerp-sel');
        });
        holder.appendChild(b);
      });
      var form = document.createElement('div');
      form.innerHTML = '<label>Name *</label><input id="gb-name">' +
        '<label>Email *</label><input id="gb-email" type="email">' +
        '<label>Phone</label><input id="gb-phone" type="tel">' +
        '<label>Anything we should know?</label><textarea id="gb-note"></textarea>' +
        '<button type="button" class="growerp-book">Book appointment</button>' +
        '<div class="growerp-status"></div>';
      holder.appendChild(form);
      var status = form.querySelector('.growerp-status');
      form.querySelector('.growerp-book').addEventListener('click', function(){
        var name = document.getElementById('gb-name').value.trim();
        var email = document.getElementById('gb-email').value.trim();
        if (!selected) { status.className='growerp-status growerp-err';
          status.textContent = 'Please pick a time slot first'; return; }
        if (!name || !email) { status.className='growerp-status growerp-err';
          status.textContent = 'Name and email are required'; return; }
        status.className='growerp-status'; status.textContent='…';
        fetch(api, {method:'POST',
          headers:{'Content-Type':'application/json','Accept':'application/json'},
          body: JSON.stringify({slotId: selected, name: name, email: email,
            phone: document.getElementById('gb-phone').value,
            note: document.getElementById('gb-note').value})})
          .then(function(r){ return r.json().then(function(j){ return {ok:r.ok, j:j}; }); })
          .then(function(res){
            if (res.ok) { holder.innerHTML =
              '<div class="growerp-status growerp-ok">✓ Your appointment is booked. ' +
              'A confirmation email is on its way.</div>'; }
            else { status.className='growerp-status growerp-err';
              status.textContent = (res.j && res.j.errors) ? res.j.errors :
                'Could not book, please try another slot'; }
          }).catch(function(){ status.className='growerp-status growerp-err';
            status.textContent = 'Could not book, please try again'; });
      });
    });
})();
</script>
        ]]></text></render-mode>
        <render-mode><text type="html" location="${template_server_footer}"/></render-mode>
    </widgets>
</screen>
