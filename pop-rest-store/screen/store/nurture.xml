<!-- Browser-facing endpoints for nurture-sequence emails: unsubscribe page,
     open-tracking pixel and click-tracking redirect. Links are generated by
     growerp.100.NurtureServices100.process#SequenceEnrollment and the outreach
     email services. -->
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-2.1.xsd"
    require-authentication="anonymous-all" allow-extra-path="true" history="false">

    <transition name="unsubscribe" read-only="true">
        <parameter name="id"/><parameter name="token"/>
        <parameter name="email"/><parameter name="campaign"/>
        <actions>
            <service-call name="growerp.100.NurtureServices100.unsubscribe#Enrollment"
                ignore-error="true"
                in-map="[enrollmentId: id, token: token, emailAddress: email]"/>
            <script><![CDATA[
                ec.web.sendTextResponse('<!DOCTYPE html><html><head><title>Unsubscribed</title>' +
                    '<meta name="viewport" content="width=device-width, initial-scale=1"></head>' +
                    '<body style="font-family:Arial,sans-serif;text-align:center;padding-top:80px;">' +
                    '<h2>You have been unsubscribed</h2>' +
                    '<p>You will not receive further emails from this list.</p>' +
                    '</body></html>', 'text/html', null)
            ]]></script>
        </actions>
        <default-response type="none"/>
    </transition>

    <transition name="open" read-only="true">
        <parameter name="id"/><parameter name="token"/>
        <actions>
            <service-call name="growerp.100.NurtureServices100.track#EmailOpen"
                ignore-error="true" in-map="[enrollmentId: id, token: token]"/>
            <script><![CDATA[
                byte[] gif = java.util.Base64.decoder.decode(
                    'R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7')
                def resp = ec.web.response
                resp.setContentType('image/gif')
                resp.setContentLength(gif.length)
                resp.outputStream.write(gif)
                resp.outputStream.flush()
            ]]></script>
        </actions>
        <default-response type="none"/>
    </transition>

    <transition name="click" read-only="true">
        <parameter name="id"/><parameter name="token"/><parameter name="url"/>
        <actions>
            <service-call name="growerp.100.NurtureServices100.track#EmailClick"
                ignore-error="true" in-map="[enrollmentId: id, token: token]"/>
            <script><![CDATA[
                String target = url ?: '/'
                // only allow http(s) targets to avoid open-redirect abuse of other schemes
                if (!target.startsWith('http://') && !target.startsWith('https://')
                        && !target.startsWith('/')) target = '/'
                ec.web.response.sendRedirect(target)
            ]]></script>
        </actions>
        <default-response type="none"/>
    </transition>

    <widgets><!-- direct /nurture hit: nothing to show -->
        <label text=""/>
    </widgets>
</screen>
