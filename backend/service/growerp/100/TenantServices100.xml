<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-2.1.xsd">

    <service verb="create" noun="Tenant" authenticate="anonymous-all">
        <description>
            Create a new tenant (owner party) with admin user and main company.
            This service is called during new tenant registration.
        </description>
        <in-parameters>
            <parameter name="adminEmail" required="true"/>
            <parameter name="adminFirstName" required="true"/>
            <parameter name="adminLastName" required="true"/>
            <parameter name="password" default="org.moqui.util.StringUtilities.getRandomString(6) + '9!'"/>
            <parameter name="classificationId" required="true"/>
            <parameter name="timeZoneOffset"/>
            <parameter name="locale"/>
        </in-parameters>
        <out-parameters>
            <parameter name="ownerPartyId"/>
            <parameter name="companyPartyId"/>
            <parameter name="adminPartyId"/>
            <parameter name="adminUserId"/>
        </out-parameters>
        <actions>
            <!-- Set locale for error messages -->
            <if condition="locale">
                <script>ec.user.setLocale(new Locale(locale))</script>
            </if>

            <!-- Check if GROWERP party exists (from seed data) -->
            <entity-find-one entity-name="mantle.party.Party" value-field="growerpParty">
                <field-map field-name="partyId" value="GROWERP"/>
            </entity-find-one>

            <if condition="growerpParty">
                <!-- GROWERP exists from seed data - check if it has any users -->
                <entity-find entity-name="mantle.party.Party" list="growerpUsers">
                    <econdition field-name="ownerPartyId" value="GROWERP"/>
                    <econdition field-name="partyTypeEnumId" operator="not-equals" value="PtyOwner"/>
                </entity-find>
                
                <if condition="!growerpUsers">
                    <!-- GROWERP exists but has no users - this is the first registration -->
                    <log message="First registration: Using existing GROWERP party from seed data"/>
                    <set field="ownerPartyId" value="GROWERP"/>
                <else>
                    <!-- GROWERP has users - create new tenant -->
                    <log message="Creating additional tenant (GROWERP already has users)"/>
                    <service-call name="create#mantle.party.Party"
                        in-map="[partyTypeEnumId: 'PtyOwner', disabled: 'Y']"
                        out-map="owner"/>
                    <set field="ownerPartyId" from="owner.partyId"/>
                </else>
                </if>
            <else>
                <!-- GROWERP doesn't exist - create it (shouldn't happen with seed data) -->
                <log message="Creating GROWERP party (not found in seed data)"/>
                <set field="ownerPartyId" value="GROWERP"/>
                <service-call name="create#mantle.party.Party"
                    in-map="[partyId: 'GROWERP', partyTypeEnumId: 'PtyOwner', disabled: 'Y']"/>
            </else>
            </if>

            <!-- Create temporary main company -->
            <set field="user" from="[
                userGroupId: 'GROWERP_M_ADMIN',
                role: 'OrgInternal',
                email: adminEmail,
                firstName: adminFirstName,
                lastName: adminLastName,
                loginName: adminEmail,
                timeZoneOffset: timeZoneOffset,
                locale: locale,
                company: [
                    name: 'Main Organization',
                    role: 'OrgInternal',
                    email: adminEmail
                ]
            ]"/>

            <!-- Create admin user with company -->
            <service-call name="growerp.100.PartyServices100.create#User"
                in-map="[user: user, password: password, ownerPartyId: ownerPartyId, classificationId: classificationId]"
                out-map="userResult"/>

            <set field="adminPartyId" from="userResult.user.partyId"/>
            <set field="adminUserId" from="userResult.user.userId"/>
            <set field="companyPartyId" from="userResult.user.company.partyId"/>

            <!-- Create TenantSetup record (not complete yet) -->
            <service-call name="create#growerp.general.TenantSetup"
                in-map="[ownerPartyId: ownerPartyId, setupComplete: 'N', classificationId: classificationId]"/>

            <!-- Create event for system tracking -->
            <service-call name="growerp.100.ActivityServices100.create#Event"
                in-map="[partyId: adminPartyId, userGroupId: 'GROWERP_M_SYSTEM', name: 'New tenant &amp; admin created']"/>
        </actions>
    </service>

    <service verb="complete" noun="TenantSetup">
        <description>
            Complete tenant setup after admin provides company name, currency, and demo data preference.
            This activates the owner party and initializes the organizational structure.
        </description>
        <in-parameters>
            <parameter name="ownerPartyId" required="true"/>
            <parameter name="companyPartyId" required="true"/>
            <parameter name="companyName" required="true"/>
            <parameter name="currencyId" required="true"/>
            <parameter name="demoData" type="Boolean" default="false"/>
            <parameter name="agentDemoData" type="Boolean" default="false"/>
            <parameter name="classificationId" required="true"/>
            <parameter name="userPartyId" required="true"/>
            <parameter name="hostName"/>
            <parameter name="timeZoneOffset"/>
        </in-parameters>
        <out-parameters>
            <parameter name="success" type="Boolean"/>
        </out-parameters>
        <actions>
            <!-- Special handling for GROWERP system administrator -->
            <if condition="ownerPartyId == 'GROWERP'">
                <!-- Force no demo data for GROWERP -->
                <set field="demoData" value="false" type="Boolean"/>
                <set field="agentDemoData" value="false" type="Boolean"/>
            </if>

            <!-- Update company name -->
            <service-call name="update#mantle.party.Organization"
                in-map="[partyId: companyPartyId, organizationName: companyName]"/>

            <!-- Activate owner party -->
            <service-call name="update#mantle.party.Party"
                in-map="[partyId: ownerPartyId, disabled: 'N']"/>

            <!-- Initialize accounting configuration -->
            <service-call name="growerp.100.AccountingServices100.init#PartyAccountingConfiguration"
                in-map="[sourcePartyId: 'DefaultSettings', organizationPartyId: companyPartyId, baseCurrencyUomId: currencyId]"/>

            <!-- Setup main organization (product store, warehouse, wiki, etc.) -->
            <service-call name="growerp.100.PartyServices100.setup#MainOrganization"
                in-map="[ownerPartyId: ownerPartyId, userPartyId: userPartyId, companyPartyId: companyPartyId, 
                         classificationId: classificationId, hostName: hostName]"/>

            <!-- App-specific setup -->
            <service-call name="growerp.100.PartyServices100.setup#SpecificApp"
                in-map="[ownerPartyId: ownerPartyId, companyPartyId: companyPartyId,
                         userPartyId: userPartyId, classificationId: classificationId,
                         demoData: demoData, agentDemoData: agentDemoData,
                         currencyId: currencyId, timeZoneOffset: timeZoneOffset]"/>

            <!-- Create trial subscription for new tenants (not GROWERP) -->
            <log message="=======creating subscription for ${ownerPartyId}"/>
            <if condition="ownerPartyId != 'GROWERP'">
                <log message="Creating 14-day trial subscription for tenant ${ownerPartyId}"/>
                <set field="evaluationDays" 
                    from="System.getProperty('evaluationDays') ? Integer.parseInt(System.getProperty('evaluationDays')) : 14"/>
                <set field="fromDate" from="ec.user.nowTimestamp"/>
                <set field="thruDate" 
                    from="java.sql.Timestamp.valueOf(fromDate.toLocalDateTime().plusDays(evaluationDays))"/>
                
                <!-- Check if customer party for this tenant already exists in GROWERP -->
                <entity-find entity-name="mantle.product.subscription.Subscription" list="existingSubscriptions">
                    <econdition field-name="ownerPartyId" value="GROWERP"/>
                    <econdition field-name="externalSubscriptionId" from="ownerPartyId"/>
                    <order-by field-name="-fromDate"/>
                </entity-find>
                
                <if condition="existingSubscriptions">
                    <!-- Reuse existing subscriber party -->
                    <set field="subscriberPartyId" from="existingSubscriptions[0].subscriberPartyId"/>
                    <log message="Found existing customer party ${subscriberPartyId} for tenant ${ownerPartyId}"/>
                <else>
                    <!-- Get admin user info from the tenant using get#User -->
                    <service-call name="growerp.100.PartyServices100.get#User"
                        out-map="adminUserResult"
                        in-map="[userPartyId: userPartyId]"/>
                    <set field="adminUser" from="adminUserResult.users ? adminUserResult.users[0] : null"/>
                    <log message="Retrieved admin user for subscription: ${adminUser?.firstName} ${adminUser?.lastName} ${adminUser?.email}"/>
                    
                    <!-- Create a customer (user + company) in GROWERP using create#User service -->
                    <service-call name="growerp.100.PartyServices100.create#User"
                        out-map="tenantCustomer"
                        in-map="[
                            ownerPartyId: 'GROWERP',
                            user: [
                                firstName: adminUser?.firstName ?: 'Tenant',
                                lastName: adminUser?.lastName ?: ownerPartyId,
                                email: adminUser?.email ?: '',
                                role: 'Customer',
                                loginDisabled: true,
                                company: [
                                    name: companyName,
                                    role: 'Customer',
                                    email: adminUser?.email ?: ''
                                ]
                            ]
                        ]"/>
                    <set field="subscriberPartyId" from="tenantCustomer.user.company.partyId"/>
                    <log message="Created customer via create#User: company partyId=${subscriberPartyId}, user partyId=${tenantCustomer.user.partyId} for tenant ${ownerPartyId} in GROWERP"/>
                </else>
                </if>
                
                <!-- Create trial subscription in GROWERP tenant with customer as subscriber -->
                <set field="description" value="${evaluationDays}-day trial subscription"/>
                <service-call name="growerp.100.SubscriptionServices100.create#Subscription"
                    in-map="[
                        ownerPartyId: 'GROWERP',
                        subscription: [
                            description: description,
                            fromDate: fromDate,
                            thruDate: thruDate,
                            subscriber: [partyId: subscriberPartyId],
                            product: [productId: 'GROWERP_SMALL_PLAN'],
                            externalId: ownerPartyId
                        ]
                    ]"
                    out-map="subscriptionResult"/>
                <log message="Trial subscription created: ${subscriptionResult.subscription?.pseudoId} - ${evaluationDays} days until ${thruDate} for subscriber ${subscriberPartyId}"/>
            </if>

            <!-- Load ERP landing page data, onboarding assessment and the official
                 GROWERP marketing website (all GROWERP-owner-scoped) after the GROWERP
                 tenant org/store is set up -->
            <if condition="ownerPartyId == 'GROWERP'">
                <script><![CDATA[
                    ec.entity.makeDataLoader().location("component://growerp/data/ErpLandingPageData.xml").load()
                    ec.entity.makeDataLoader().location("component://growerp/data/ErpOnboardAssessmentData.xml").load()
                    ec.entity.makeDataLoader().location("component://growerp/data/GrowerpWebsiteSeedData.xml").load()
                    // self-marketing sprint content: MarketingCampaign references
                    // landingPageId=ERP_LANDING_PAGE just loaded above
                    ec.entity.makeDataLoader().location("component://growerp/data/GrowerpMarketingContentData.xml").load()
                ]]></script>
                <service-call name="update#growerp.Application" in-map="[applicationId: 'AppAdmin', assessmentId: 'ERP_ONBOARD']"/>

                <!-- Repoint the GROWERP company store (created by setup#MainOrganization) at the
                     official marketing wiki/content just loaded, and let it serve the growerp.com
                     / growerp.org domains. The store keeps its GROWERP-owned categories. -->
                <entity-find entity-name="mantle.product.store.ProductStore" list="growerpStores">
                    <econdition field-name="organizationPartyId" from="companyPartyId"/>
                </entity-find>
                <if condition="growerpStores">
                    <set field="growerpStoreId" from="growerpStores[0].productStoreId"/>
                    <!-- GROWERP_WS normally comes from GrowerpWebsiteSeedData.xml loaded above;
                         create a minimal space when absent (e.g. that load failed) so the
                         ProductStore foreign key below can never abort tenant setup -->
                    <entity-find-one entity-name="moqui.resource.wiki.WikiSpace" value-field="growerpWikiSpace">
                        <field-map field-name="wikiSpaceId" value="GROWERP_WS"/>
                    </entity-find-one>
                    <if condition="growerpWikiSpace == null">
                        <service-call name="create#moqui.resource.wiki.WikiSpace"
                            in-map="[wikiSpaceId: 'GROWERP_WS', description: 'GrowERP Official Website Content',
                                allowAnyHtml: 'Y', rootPageLocation: 'dbresource://GROWERP_ROOT']"/>
                    </if>
                    <service-call name="update#mantle.product.store.ProductStore"
                        in-map="[productStoreId: growerpStoreId, storeName: 'GrowERP', wikiSpaceId: 'GROWERP_WS']"/>

                    <!-- serve the marketing site with the modern (Tailwind/Lumina) template set -->
                    <entity-find entity-name="mantle.product.store.ProductStoreSetting" list="templateIdSettings">
                        <econdition field-name="productStoreId" from="growerpStoreId"/>
                        <econdition field-name="settingTypeEnumId" value="PsstTemplateId"/>
                    </entity-find>
                    <if condition="templateIdSettings">
                        <service-call name="update#mantle.product.store.ProductStoreSetting"
                            in-map="templateIdSettings[0] + [settingValue: 'modern']"/>
                        <else>
                            <service-call name="create#mantle.product.store.ProductStoreSetting"
                                in-map="[productStoreId: growerpStoreId, settingTypeEnumId: 'PsstTemplateId', settingValue: 'modern']"/>
                        </else>
                    </if>

                    <!-- point content location at the marketing DbResource tree -->
                    <entity-find entity-name="mantle.product.store.ProductStoreSetting" list="contentSettings">
                        <econdition field-name="productStoreId" from="growerpStoreId"/>
                        <econdition field-name="settingTypeEnumId" value="PsstContentLocation"/>
                    </entity-find>
                    <iterate list="contentSettings" entry="contentSetting">
                        <service-call name="update#mantle.product.store.ProductStoreSetting"
                            in-map="contentSetting + [settingValue: 'dbresource://GROWERP_ROOT']"/>
                    </iterate>

                    <!-- Let the public store resolve on the official marketing hosts. These are
                         explicit hostnames (not broad regex) so they match ONLY the GROWERP
                         marketing site and never shadow a tenant store served on a
                         *.growerp.com / *.growerp.org subdomain. The original cloned
                         "<storeId>.localhost" row is left untouched. PsstHostname is matched as a
                         regex by PopRestStore (StoreServices). -->
                    <service-call name="create#mantle.product.store.ProductStoreSetting"
                        in-map="[productStoreId: growerpStoreId, settingTypeEnumId: 'PsstHostname',
                                 fromDate: java.sql.Timestamp.valueOf('2024-01-01 00:00:00'), settingValue: 'growerp.com']"/>
                    <service-call name="create#mantle.product.store.ProductStoreSetting"
                        in-map="[productStoreId: growerpStoreId, settingTypeEnumId: 'PsstHostname',
                                 fromDate: java.sql.Timestamp.valueOf('2024-01-02 00:00:00'), settingValue: 'www.growerp.com']"/>
                    <service-call name="create#mantle.product.store.ProductStoreSetting"
                        in-map="[productStoreId: growerpStoreId, settingTypeEnumId: 'PsstHostname',
                                 fromDate: java.sql.Timestamp.valueOf('2024-01-03 00:00:00'), settingValue: 'growerp.org']"/>
                    <service-call name="create#mantle.product.store.ProductStoreSetting"
                        in-map="[productStoreId: growerpStoreId, settingTypeEnumId: 'PsstHostname',
                                 fromDate: java.sql.Timestamp.valueOf('2024-01-04 00:00:00'), settingValue: 'www.growerp.org']"/>
                </if>
            </if>

            <!-- Mark tenant setup as complete -->
            <service-call name="update#growerp.general.TenantSetup"
                in-map="[ownerPartyId: ownerPartyId, setupComplete: 'Y', setupCompletedDate: ec.user.nowTimestamp]"/>

            <set field="success" value="true" type="Boolean"/>
        </actions>
    </service>

    <service verb="check" noun="TenantSubscription">
        <description>
            Check if tenant has an active subscription.
            Uses the existing SubscriptionServices100.get#Subscription to query GROWERP tenant
            for subscriptions where externalSubscriptionId matches the tenant's ownerPartyId.
        </description>
        <in-parameters>
            <parameter name="ownerPartyId" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="hasActiveSubscription" type="Boolean"/>
            <parameter name="subscriptionStatus"/><!-- 'active', 'trial', 'expired', 'none' -->
            <parameter name="expiryDate" type="Timestamp"/>
            <parameter name="daysRemaining" type="Integer"/>
            <parameter name="subscription" type="Map"/>
        </out-parameters>
        <actions>
            <!-- Query subscriptions in GROWERP tenant where externalId = ownerPartyId -->
            <!-- cache="false" ensures fresh data is read (important for multi-device login scenarios) -->
            <entity-find entity-name="mantle.product.subscription.Subscription" list="subscriptions" cache="false">
                <econdition field-name="ownerPartyId" value="GROWERP"/>
                <econdition field-name="externalSubscriptionId" from="ownerPartyId"/>
                <date-filter/>
                <order-by field-name="-fromDate"/>
            </entity-find>
            <log message="check#TenantSubscription: ownerPartyId=${ownerPartyId}, found ${subscriptions?.size() ?: 0} subscriptions, nowTimestamp=${ec.user.nowTimestamp}"/>

            <if condition="subscriptions">
                <then>
                    <set field="subscription" from="subscriptions[0]"/>
                    <set field="expiryDate" from="subscription.thruDate"/>
                    
                    <!-- Calculate days remaining -->
                    <if condition="expiryDate">
                        <set field="now" from="ec.user.nowTimestamp"/>
                        <set field="millisRemaining" from="expiryDate.time - now.time"/>
                        <set field="daysRemaining" from="(int)(millisRemaining / (1000 * 60 * 60 * 24))" type="Integer"/>
                        <log message="check#TenantSubscription: expiryDate=${expiryDate}, now=${now}, daysRemaining=${daysRemaining}, millisRemaining=${millisRemaining}"/>
                        
                        <!-- Subscription is active if expiry date hasn't passed yet (millisRemaining >= 0) -->
                        <!-- Using millisRemaining instead of daysRemaining to handle same-day scenarios correctly -->
                        <if condition="millisRemaining >= 0">
                            <set field="hasActiveSubscription" value="true" type="Boolean"/>
                            <set field="subscriptionStatus" value="active"/>
                            <!-- Ensure daysRemaining is at least 0 for display purposes -->
                            <if condition="daysRemaining &lt; 0">
                                <set field="daysRemaining" value="0" type="Integer"/>
                            </if>
                        <else>
                            <set field="hasActiveSubscription" value="false" type="Boolean"/>
                            <set field="subscriptionStatus" value="expired"/>
                            <set field="daysRemaining" value="0" type="Integer"/>
                        </else>
                        </if>
                    <else>
                        <!-- No expiry date means permanent/active -->
                        <set field="hasActiveSubscription" value="true" type="Boolean"/>
                        <set field="subscriptionStatus" value="active"/>
                        <set field="daysRemaining" value="-1" type="Integer"/><!-- -1 = unlimited -->
                    </else>
                    </if>
                </then>
                <else>
                    <!-- No subscription found -->
                    <set field="hasActiveSubscription" value="false" type="Boolean"/>
                    <set field="subscriptionStatus" value="none"/>
                    <set field="daysRemaining" value="0" type="Integer"/>
                </else>
            </if>
        </actions>
    </service>

    <service verb="get" noun="SubscriptionPlans" authenticate="anonymous-all">
        <description>Public list of the GROWERP subscription plan products with their
            current purchase price, for pricing pages and plan selection.</description>
        <out-parameters>
            <parameter name="plans" type="List">
                <parameter name="planEntry" type="Map">
                    <parameter name="productId" />
                    <parameter name="productName" />
                    <parameter name="description" />
                    <parameter name="price" />
                    <parameter name="currencyUomId" />
                </parameter>
            </parameter>
        </out-parameters>
        <actions>
            <entity-find entity-name="mantle.product.Product" list="planProducts">
                <econdition field-name="ownerPartyId" value="GROWERP" />
                <econdition field-name="productTypeEnumId" value="PtService" />
                <econdition field-name="productId" operator="like" value="GROWERP_%" />
                <order-by field-name="productId" />
            </entity-find>
            <set field="plans" from="[]" />
            <iterate list="planProducts" entry="planProduct">
                <entity-find entity-name="mantle.product.ProductPrice" list="planPrices">
                    <econdition field-name="productId" from="planProduct.productId" />
                    <econdition field-name="priceTypeEnumId" value="PptCurrent" />
                    <econdition field-name="pricePurposeEnumId" value="PppPurchase" />
                    <date-filter />
                    <order-by field-name="-fromDate" />
                </entity-find>
                <if condition="planPrices">
                    <script>plans.add([productId: planProduct.productId,
                        productName: planProduct.productName,
                        description: planProduct.description,
                        price: planPrices[0].price.toString(),
                        currencyUomId: planPrices[0].priceUomId ?: 'USD'])</script>
                </if>
            </iterate>
        </actions>
    </service>

    <service verb="renew" noun="TenantSubscription">
        <description>
            Renew an expired tenant subscription: charge the selected plan (converted from
            the plan price currency to the receiving GROWERP company base currency) and
            extend the subscription in the GROWERP tenant by one month.
            Called from login#User when the subscription is expired and card data is
            provided, and from renew#DueTenantSubscriptions (auto-renewal) without card
            data when the subscriber already has a stored payment method.
        </description>
        <in-parameters>
            <parameter name="ownerPartyId" required="true" />
            <parameter name="plan" required="true">
                <description>productId of the GROWERP subscription plan</description>
            </parameter>
            <!-- card fields optional: not needed when a payment method is stored -->
            <parameter name="creditCardNumber" />
            <parameter name="creditCardType" />
            <parameter name="nameOnCard" />
            <parameter name="expireMonth" />
            <parameter name="expireYear" />
            <parameter name="cVC" />
        </in-parameters>
        <out-parameters>
            <parameter name="subscriptionId" />
            <parameter name="paymentId" />
        </out-parameters>
        <actions>
            <!-- validate the plan is a GROWERP-owned plan product and get its current price -->
            <entity-find-one entity-name="mantle.product.Product" value-field="planProduct">
                <field-map field-name="productId" from="plan" />
            </entity-find-one>
            <if condition="!planProduct || planProduct.ownerPartyId != 'GROWERP'">
                <return error="true" message="Invalid subscription plan ${plan}" />
            </if>
            <entity-find entity-name="mantle.product.ProductPrice" list="planPrices">
                <econdition field-name="productId" from="plan" />
                <econdition field-name="priceTypeEnumId" value="PptCurrent" />
                <econdition field-name="pricePurposeEnumId" value="PppPurchase" />
                <date-filter />
                <order-by field-name="-fromDate" />
            </entity-find>
            <if condition="!planPrices">
                <return error="true" message="No price found for subscription plan ${plan}" />
            </if>
            <set field="amount" from="planPrices[0].price" />
            <set field="priceCurrencyUomId" from="planPrices[0].priceUomId ?: 'USD'" />

            <!-- the GROWERP main company receives the payment -->
            <entity-find entity-name="mantle.party.PartyDetailAndRole" limit="1" list="companyList">
                <econdition field-name="ownerPartyId" value="GROWERP" />
                <econdition field-name="partyTypeEnumId" value="PtyOrganization" />
                <econdition field-name="roleTypeId" value="OrgInternal" />
            </entity-find>
            <if condition="!companyList">
                <return error="true" message="GROWERP company not found" />
            </if>
            <set field="companyPartyId" from="companyList[0].partyId" />
            <entity-find-one entity-name="mantle.ledger.config.PartyAcctgPreference"
                value-field="acctgPref">
                <field-map field-name="organizationPartyId" from="companyPartyId" />
            </entity-find-one>
            <set field="baseCurrencyUomId"
                from="acctgPref?.baseCurrencyUomId ?: priceCurrencyUomId" />

            <!-- the tenant's customer party in GROWERP, created with the trial subscription -->
            <entity-find entity-name="mantle.product.subscription.Subscription"
                list="subscriptions" cache="false">
                <econdition field-name="ownerPartyId" value="GROWERP" />
                <econdition field-name="externalSubscriptionId" from="ownerPartyId" />
                <order-by field-name="-fromDate" />
            </entity-find>
            <if condition="!subscriptions">
                <return error="true"
                    message="No subscription found for tenant ${ownerPartyId}, cannot renew" />
            </if>
            <set field="subscription" from="subscriptions[0]" />
            <set field="subscriberPartyId" from="subscription.subscriberPartyId" />

            <!-- find or create the payment method -->
            <entity-find entity-name="mantle.account.method.PaymentMethod" list="pms">
                <econdition field-name="ownerPartyId" from="subscriberPartyId" />
            </entity-find>
            <if condition="pms">
                <set field="paymentMethodId" from="pms[0].paymentMethodId" />
                <else>
                    <if condition="!creditCardNumber">
                        <return error="true"
                            message="No stored payment method and no card data provided for tenant ${ownerPartyId}" />
                    </if>
                    <!-- match card type against Enumeration description ignoring spaces/case
                         (frontend sends e.g. 'Mastercard', seed description is 'Master Card') -->
                    <entity-find entity-name="moqui.basic.Enumeration" list="cctEnums" cache="true">
                        <econdition field-name="enumTypeId" value="CreditCardType" />
                    </entity-find>
                    <set field="creditCardTypeEnumId" from="cctEnums.find {
                            it.description.replace(' ', '').equalsIgnoreCase((creditCardType ?: '').replace(' ', ''))
                        }?.enumId" />
                    <set field="expireDate" value="${expireMonth}/20${expireYear}" />
                    <service-call name="mantle.account.PaymentMethodServices.create#CreditCard"
                        in-map="[
                                paymentMethodTypeEnumId: 'PmtCreditCard',
                                ownerPartyId: subscriberPartyId,
                                cardNumber: creditCardNumber,
                                creditCardTypeEnumId: creditCardTypeEnumId,
                                expireDate: expireDate,
                                firstNameOnAccount: nameOnCard,
                                lastNameOnAccount: '',
                                paymentGatewayConfigId: System.getProperty('paymentGatewayConfigId'),
                                ]"
                        out-map="ccOut" />
                    <set field="paymentMethodId" from="ccOut.paymentMethodId" />
                </else>
            </if>

            <!-- convert the plan price to the receiving company base currency -->
            <set field="paymentAmount" from="amount" />
            <set field="paymentCurrencyUomId" from="priceCurrencyUomId" />
            <if condition="baseCurrencyUomId != priceCurrencyUomId">
                <service-call name="growerp.100.GeneralServices100.convert#Currency"
                    in-map="[amount: amount, fromCurrencyUomId: priceCurrencyUomId,
                        toCurrencyUomId: baseCurrencyUomId]"
                    out-map="conversion" />
                <if condition="conversion.converted">
                    <set field="paymentAmount" from="conversion.convertedAmount" />
                    <set field="paymentCurrencyUomId" from="baseCurrencyUomId" />
                    <set field="originalCurrencyAmount" from="amount" />
                    <set field="originalCurrencyUomId" from="priceCurrencyUomId" />
                </if>
            </if>

            <!-- create and capture the payment -->
            <service-call name="growerp.100.GeneralServices100.getNext#PseudoId"
                in-map="[ownerPartyId: 'GROWERP', seqName: 'payment']" out-map="context" />
            <service-call name="create#mantle.account.payment.Payment"
                in-map="[   statusId: 'PmntPromised',
                            pseudoId: seqNum,
                            paymentType: 'PtPrePayment',
                            paymentMethodId: paymentMethodId,
                            amount: paymentAmount,
                            amountUomId: paymentCurrencyUomId,
                            originalCurrencyAmount: originalCurrencyAmount,
                            originalCurrencyUomId: originalCurrencyUomId,
                            paymentInstrumentEnumId: 'PiCreditCard',
                            effectiveDate: ec.user.nowTimestamp,
                            paymentTypeEnumId: 'PmtCreditCard',
                            fromPartyId: subscriberPartyId,
                            toPartyId: companyPartyId,
                            memo: 'GrowERP plan renewal: ' + (planProduct.productName ?: plan),
                            ]"
                out-map="paymentInfo" />
            <set field="paymentId" from="paymentInfo.paymentId" />
            <if condition="System.getProperty('paymentGatewayConfigId') == 'STRIPE'">
                <service-call name="Stripe.StripePaymentServices.authorizeAndCapture#Payment"
                    in-map="[paymentId: paymentId,
                        paymentGatewayConfigId: System.getProperty('paymentGatewayConfigId')]" />
            </if>

            <!-- extend the subscription one month from now (or from thruDate when still in the future) -->
            <set field="extendFrom"
                from="subscription.thruDate != null &amp;&amp; subscription.thruDate.time &gt; ec.user.nowTimestamp.time ?
                    subscription.thruDate : ec.user.nowTimestamp" />
            <set field="newThruDate"
                from="java.sql.Timestamp.valueOf(extendFrom.toLocalDateTime().plusMonths(1))" />
            <service-call name="update#mantle.product.subscription.Subscription"
                in-map="[subscriptionId: subscription.subscriptionId,
                    productId: plan,
                    thruDate: newThruDate,
                    description: 'GrowERP plan: ' + (planProduct.productName ?: plan)]" />
            <set field="subscriptionId" from="subscription.subscriptionId" />
            <log
                message="Renewed subscription ${subscriptionId} for tenant ${ownerPartyId} until ${newThruDate}, payment ${paymentId} ${paymentAmount} ${paymentCurrencyUomId}" />
        </actions>
    </service>

    <service verb="renew" noun="DueTenantSubscriptions" authenticate="false"
        allow-remote="false" transaction-timeout="600">
        <description>Auto-renewal batch (daily cron): renew tenant subscriptions that
            expire within 3 days (or expired up to 3 days ago, the dunning grace window)
            when the subscriber has a stored payment method. On a failed charge the
            tenant admin gets a PAYMENT_FAILED email; after the grace window the login
            paywall takes over.</description>
        <out-parameters>
            <parameter name="renewedCount" type="Integer" />
            <parameter name="failedCount" type="Integer" />
        </out-parameters>
        <actions>
            <set field="windowStart"
                from="new java.sql.Timestamp(ec.user.nowTimestamp.time - 3L * 86400000L)" />
            <set field="windowEnd"
                from="new java.sql.Timestamp(ec.user.nowTimestamp.time + 3L * 86400000L)" />
            <entity-find entity-name="mantle.product.subscription.Subscription"
                list="dueSubscriptions" cache="false">
                <econdition field-name="ownerPartyId" value="GROWERP" />
                <econdition field-name="externalSubscriptionId" operator="is-not-null" />
                <econdition field-name="thruDate" operator="greater-equals"
                    from="windowStart" />
                <econdition field-name="thruDate" operator="less-equals" from="windowEnd" />
            </entity-find>
            <set field="renewedCount" from="0" />
            <set field="failedCount" from="0" />
            <iterate list="dueSubscriptions" entry="dueSubscription">
                <!-- only auto-renew when a payment method is stored -->
                <entity-find entity-name="mantle.account.method.PaymentMethod" list="pms"
                    limit="1">
                    <econdition field-name="ownerPartyId"
                        from="dueSubscription.subscriberPartyId" />
                </entity-find>
                <if condition="!pms">
                    <continue />
                </if>
                <set field="oldThruDate" from="dueSubscription.thruDate" />
                <service-call name="growerp.100.TenantServices100.renew#TenantSubscription"
                    ignore-error="true"
                    in-map="[ownerPartyId: dueSubscription.externalSubscriptionId,
                        plan: dueSubscription.productId]" />
                <!-- detect the outcome by whether the thruDate moved -->
                <entity-find-one entity-name="mantle.product.subscription.Subscription"
                    value-field="checkSubscription" cache="false">
                    <field-map field-name="subscriptionId"
                        from="dueSubscription.subscriptionId" />
                </entity-find-one>
                <if condition="checkSubscription.thruDate != oldThruDate">
                    <then>
                        <set field="renewedCount" from="renewedCount + 1" />
                    </then>
                    <else>
                        <set field="failedCount" from="failedCount + 1" />
                        <!-- dunning email to the tenant admin when email is configured -->
                        <entity-find-one entity-name="moqui.basic.email.EmailServer"
                            value-field="emailServer">
                            <field-map field-name="emailServerId" value="SYSTEM" />
                        </entity-find-one>
                        <entity-find entity-name="growerp.party.OwnerPersonDetailAndCompany"
                            list="admins" limit="1">
                            <econdition field-name="ownerPartyId"
                                from="dueSubscription.externalSubscriptionId" />
                            <econdition field-name="userGroupId" value="GROWERP_M_ADMIN" />
                            <econdition field-name="emailAddress" operator="is-not-null" />
                        </entity-find>
                        <if condition="emailServer &amp;&amp;
                                emailServer.mailPassword != 'SMTP_PASSWORD'
                                &amp;&amp; admins">
                            <service-call
                                name="org.moqui.impl.EmailServices.send#EmailTemplate"
                                async="true" ignore-error="true"
                                in-map="[emailTemplateId: 'PAYMENT_FAILED',
                                    toAddresses: admins[0].emailAddress,
                                    bodyParameters: [
                                        firstName: admins[0].firstName,
                                        expiryDate:
                                            dueSubscription.thruDate.toString()]]" />
                        </if>
                    </else>
                </if>
            </iterate>
            <log
                message="renew#DueTenantSubscriptions: renewed ${renewedCount}, failed ${failedCount}" />
        </actions>
    </service>

    <service verb="check" noun="TenantSetupStatus">
        <description>
            Check if tenant setup is complete.
        </description>
        <in-parameters>
            <parameter name="ownerPartyId" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="setupComplete" type="Boolean"/>
            <parameter name="setupCompletedDate" type="Timestamp"/>
            <parameter name="classificationId"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="growerp.general.TenantSetup" value-field="tenantSetup">
                <field-map field-name="ownerPartyId"/>
            </entity-find-one>

            <if condition="tenantSetup">
                <set field="setupComplete" from="tenantSetup.setupComplete == 'Y'" type="Boolean"/>
                <set field="setupCompletedDate" from="tenantSetup.setupCompletedDate"/>
                <set field="classificationId" from="tenantSetup.classificationId"/>
            <else>
                <set field="setupComplete" value="false" type="Boolean"/>
            </else>
            </if>
        </actions>
    </service>

</services>
