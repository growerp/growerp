<entity-facade-xml type="seed-initial">

    <!-- Service Job: Recalculate GL Account Org Summaries - once per hour by default -->
    <moqui.service.job.ServiceJob jobName="recalculate_growerp_statistics"
        description="Recalculate the growerp dashboard statistics"
        serviceName="growerp.100.GeneralServices100.get#Statistics" cronExpression="0 0 * * * ?"
        paused="N"
        transactionTimeout="1800" />

    <!-- Service Job: Publish scheduled social posts - every 15 minutes -->
    <moqui.service.job.ServiceJob jobName="publish_scheduled_social_posts"
        description="Publish READY social posts whose scheduled time has arrived (Substack, LinkedIn)"
        serviceName="growerp.100.SocialPostPublishingServices100.publish#ScheduledSocialPosts"
        cronExpression="0 0/15 * * * ?"
        paused="N"
        transactionTimeout="300" />

    <!-- format time period name -->
    <moqui.basic.LocalizedMessage locale="default" original="TimePeriodBaseNameTemplate"
        localized="Y${fromLocalDate.getYear()}${timePeriodType?.lengthUomId!='TF_yr'?(timePeriodType.description.split('(?=[A-Z])')[1][0].toLowerCase())+(periodNum as String).padLeft(2,'0'):''}" />

    <!-- growerp initial products -->
    <mantle.party.Party partyId="GROWERP" partyTypeEnumId="PtyOwner" disabled="Y" />
    <mantle.product.category.ProductCategory productCategoryId="GROWERP_SERVICES"
        ownerPartyId="GROWERP" productCategoryTypeEnumId="PctCatalog"
        categoryName="GrowERP Services" description="" />

    <!-- Subscription Plans -->
    <mantle.product.Product productId="GROWERP_DIY_PLAN" productTypeEnumId="PtService"
        ownerPartyId="GROWERP" productName="GrowERP do it yourself plan"
        description="DIY Plan $49 per month|Full functionality, unlimited users!|support charged extra $75/hr" />
    <mantle.product.ProductPrice productId="GROWERP_DIY_PLAN" priceTypeEnumId="PptCurrent"
        price="49.00" pricePurposeEnumId="PppPurchase" priceUomId="USD" />
    <mantle.product.category.ProductCategoryMember productCategoryId="GROWERP_SERVICES"
        productId="GROWERP_DIY_PLAN" fromDate="2024-01-01 00:00:00" />

    <mantle.product.Product productId="GROWERP_SMALL_PLAN" productTypeEnumId="PtService"
        ownerPartyId="GROWERP" productName="GrowERP small Company plan"
        description="Small Company Plan $499 per month|Full functionality, unlimited users|including support for 20hrs/month" />
    <mantle.product.ProductPrice productId="GROWERP_SMALL_PLAN" priceTypeEnumId="PptCurrent"
        price="499.00" pricePurposeEnumId="PppPurchase" priceUomId="USD" />
    <mantle.product.category.ProductCategoryMember productCategoryId="GROWERP_SERVICES"
        productId="GROWERP_SMALL_PLAN" fromDate="2024-01-01 00:00:00" />

    <mantle.product.Product productId="GROWERP_FULL_PLAN" productTypeEnumId="PtService"
        ownerPartyId="GROWERP" productName="GrowERP full company plan"
        description="Full Company Plan $999 per month|Full functionality, unlimited users|including support for 40hrs/month" />
    <mantle.product.ProductPrice productId="GROWERP_FULL_PLAN" priceTypeEnumId="PptCurrent"
        price="999.00" pricePurposeEnumId="PppPurchase" priceUomId="USD" />
    <mantle.product.category.ProductCategoryMember productCategoryId="GROWERP_SERVICES"
        productId="GROWERP_FULL_PLAN" fromDate="2024-01-01 00:00:00" />

</entity-facade-xml>